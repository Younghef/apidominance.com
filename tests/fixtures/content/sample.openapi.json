{
  "openapi": "3.0.0",
  "info": { "title": "Sample API", "version": "1.0.0" },
  "paths": {
    "/api/data": {
      "get": {
        "parameters": [
          {
            "name": "query",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "Search query"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": { "type": "integer" },
            "description": "Max results"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "example": { "results": [{"id": 1, "name": "Item"}], "total": 1 }
              }
            }
          }
        }
      }
    }
  }
}
